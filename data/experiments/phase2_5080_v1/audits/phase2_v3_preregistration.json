{
  "schema_version": "phase2_v3_preregistration_v1",
  "status": "FROZEN_BEFORE_TRAINING",
  "objective": "target_conditioned_vhh_antigen_binding_prior",
  "claim_boundary": {
    "allowed": [
      "generic_binary_binding_prior",
      "external_target_transfer_ranking",
      "relative_pvrig_frontscreen_priority"
    ],
    "forbidden": [
      "pvrig_blocker_probability",
      "measured_affinity",
      "measured_competition",
      "therapeutic_efficacy"
    ]
  },
  "development_sources": [
    "NbBench/SARS-CoV-2/train.csv",
    "NbBench/SARS-CoV-2/val.csv",
    "NbBench/hIL6/train.csv",
    "NbBench/hIL6/val.csv"
  ],
  "formal_blocks": [
    {
      "block_id": "external_hTNFa",
      "role": "PRIMARY",
      "source": "AVIDa-hTNFa/AVIDa-hTNFa.csv",
      "primary_metric": "average_precision"
    },
    {
      "block_id": "sars_target_transfer",
      "role": "SECONDARY",
      "source": "NbBench/SARS-CoV-2/test.csv"
    },
    {
      "block_id": "hil6_mutant_transfer",
      "role": "SECONDARY",
      "source": "NbBench/hIL6/test.csv"
    }
  ],
  "seeds": [43, 53, 67],
  "development_selection_metric": "macro_target_average_precision",
  "formal_primary_metric": "average_precision",
  "eligible_baselines": [
    "prevalence",
    "frozen_esm2_cosine",
    "vhh_only",
    "esm2_pair"
  ],
  "gate": {
    "compare_to": "strongest_development_selected_eligible_baseline",
    "all_seed_deltas_positive": true,
    "paired_bootstrap_ci_level": 0.95,
    "paired_bootstrap_delta_lower_gt": 0.0,
    "paired_permutation_p_lt": 0.05,
    "bootstrap_replicates": 2000,
    "permutation_replicates": 2000,
    "null_and_target_shuffle_must_fail": true
  },
  "model": {
    "vhh_encoder": "COGNANO/VHHBERT local frozen checkpoint",
    "sequence_encoder": "esm2_t6_8M_UR50D local frozen checkpoint",
    "latent_dim": 192,
    "hidden_dim": 256,
    "dropout": 0.1,
    "loss": "weighted_bce_plus_within_target_pairwise",
    "checkpoint_rule": "maximum development macro-target average precision; earliest epoch on ties"
  },
  "training": {
    "epochs": 20,
    "batch_size": 1024,
    "learning_rate": 0.0005,
    "weight_decay": 0.0001,
    "pairwise_loss_weight": 0.25,
    "early_stopping_patience": 5,
    "device": "cuda"
  },
  "formal_unseal_policy": "one_shot_per_run_directory",
  "failure_policy": "fallback_to_strongest_eligible_baseline",
  "pvrig_panel": "data_splits/pvrig_v2_5_prospective_assay_panel.csv",
  "pvrig_deployment": "score_only_after_formal_decision_with_non_blocker_claim_boundary"
}
