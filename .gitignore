# Safety-first repository: this workspace contains hundreds of GB of data,
# model weights, environments, and docking outputs. New files are ignored by
# default and the sync script force-adds only lightweight source/docs artifacts.
*

!.gitignore
!.gitattributes
!README.md
!PROJECT_PROGRESS.md

# Keep the lightweight submission-release contract test visible to Git/CI.
!data/
data/*
!data/experiments/
data/experiments/*
!data/experiments/phase2_5080_v1/
data/experiments/phase2_5080_v1/*
!data/experiments/phase2_5080_v1/src/
data/experiments/phase2_5080_v1/src/*
!data/experiments/phase2_5080_v1/src/test_prepare_pvrig_submission_release.py
!data/experiments/phase2_5080_v1/src/monitor_pvrig_submission_release.sh
!data/experiments/phase2_5080_v1/src/test_monitor_pvrig_submission_release.py

# Keep the lightweight Support V3 production implementation and frozen trust
# records visible; runtime ESM2/contact caches remain outside the repository.
!data/experiments/phase2_5080_v1/src/materialize_phase2_v4_d_sequence_support_v3.py
!data/experiments/phase2_5080_v1/src/test_materialize_phase2_v4_d_sequence_support_v3.py
!data/experiments/phase2_5080_v1/audits/
data/experiments/phase2_5080_v1/audits/*
!data/experiments/phase2_5080_v1/audits/phase2_v4_d_sequence_support_v3_production_tests.log
!data/experiments/phase2_5080_v1/audits/phase2_v4_d_sequence_support_v3_implementation_freeze.json
!data/experiments/phase2_5080_v1/audits/phase2_v4_d_sequence_support_v3_implementation_freeze.receipt.json

# Keep the V4-D bridge deployment trust bundle visible and reproducible.
!data/reports/
data/reports/*
!data/reports/pvrig_v4_d_cross_campaign_control_bridge_deployment_v1/
data/reports/pvrig_v4_d_cross_campaign_control_bridge_deployment_v1/*
!data/reports/pvrig_v4_d_cross_campaign_control_bridge_deployment_v1/phase2_v4_d_cross_campaign_control_bridge_implementation_freeze.json
!data/reports/pvrig_v4_d_cross_campaign_control_bridge_deployment_v1/phase2_v4_d_cross_campaign_control_bridge_implementation_freeze.sha256
!data/reports/pvrig_v4_d_cross_campaign_control_bridge_deployment_v1/SHA256SUMS
!data/reports/pvrig_v4_d_cross_campaign_control_bridge_deployment_v1/run_production_bridge.sh
!data/reports/pvrig_v4_d_cross_campaign_control_bridge_deployment_v1/DEPLOYMENT_RECORD.json

# Keep the lightweight Node1 SSD Deep-QC reconciliation contracts, validators,
# and regression tests visible; all remote runtimes and heavy deliveries stay ignored.
!data/experiments/phase2_5080_v1/src/reconcile_node1_ssd_deepqc_eligible92_igfold100_v1.py
!data/experiments/phase2_5080_v1/src/test_reconcile_node1_ssd_deepqc_eligible92_igfold100_v1.py
!data/experiments/phase2_5080_v1/src/reconcile_node1_ssd_deepqc_eligible92_igfold100_v2.py
!data/experiments/phase2_5080_v1/src/test_reconcile_node1_ssd_deepqc_eligible92_igfold100_v2.py
!data/experiments/phase2_5080_v1/src/reconcile_node1_ssd_deepqc_three_state_tnp_igfold100_v3.py
!data/experiments/phase2_5080_v1/src/test_reconcile_node1_ssd_deepqc_three_state_tnp_igfold100_v3.py
!data/experiments/phase2_5080_v1/src/reconcile_node1_ssd_deepqc_three_state_tnp_igfold100_v3_1.py
!data/experiments/phase2_5080_v1/src/test_reconcile_node1_ssd_deepqc_three_state_tnp_igfold100_v3_1.py
!data/experiments/phase2_5080_v1/src/validate_pvrig_deepqc_three_state_delivery.py
!data/experiments/phase2_5080_v1/src/test_validate_pvrig_deepqc_three_state_delivery.py
!data/experiments/phase2_5080_v1/audits/node1_ssd_deepqc_eligible92_igfold100_reconciliation_v1_preregistration.json
!data/experiments/phase2_5080_v1/audits/node1_ssd_deepqc_eligible92_igfold100_reconciliation_v1_implementation_freeze.json
!data/experiments/phase2_5080_v1/audits/node1_ssd_deepqc_eligible92_igfold100_reconciliation_v2_preregistration.json
!data/experiments/phase2_5080_v1/audits/node1_ssd_deepqc_eligible92_igfold100_reconciliation_v2_implementation_freeze.json
!data/experiments/phase2_5080_v1/audits/node1_ssd_deepqc_three_state_tnp_igfold100_reconciliation_v3_preregistration.json
!data/experiments/phase2_5080_v1/audits/node1_ssd_deepqc_three_state_tnp_igfold100_reconciliation_v3_implementation_freeze.json
