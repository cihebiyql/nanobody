# Safety-first repository: this workspace contains hundreds of GB of data,
# model weights, environments, and docking outputs. New files are ignored by
# default and the sync script force-adds only lightweight source/docs artifacts.
*

!.gitignore
!.gitattributes
!README.md
!PROJECT_PROGRESS.md

# Keep the lightweight submission-release contract test visible to Git/CI.
!data/
data/*
!data/experiments/
data/experiments/*
!data/experiments/phase2_5080_v1/
data/experiments/phase2_5080_v1/*
!data/experiments/phase2_5080_v1/src/
data/experiments/phase2_5080_v1/src/*
!data/experiments/phase2_5080_v1/src/test_prepare_pvrig_submission_release.py
!data/experiments/phase2_5080_v1/src/monitor_pvrig_submission_release.sh
!data/experiments/phase2_5080_v1/src/test_monitor_pvrig_submission_release.py
